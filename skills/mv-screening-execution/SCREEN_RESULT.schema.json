{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mv-screening-execution/SCREEN_RESULT.schema.json",
  "title": "Screen Result v1",
  "type": "object",
  "required": [
    "schema_version",
    "fund_id",
    "generated_at_utc",
    "runs",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "screen-result-v1"
    },
    "fund_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "status",
          "scope"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "executed",
              "skipped_missing_input",
              "skipped_condition_false",
              "failed_validation",
              "failed_error"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "universe",
              "holdings"
            ]
          },
          "result_count": {
            "type": "integer",
            "minimum": 0
          },
          "reason": {
            "type": "string",
            "description": "When status is not executed, explain why. When executed, optional short note on what this run surfaced (indicator focus); not a substitute for per-candidate candidate_reason."
          }
        },
        "additionalProperties": true
      }
    },
    "candidates": {
      "description": "Universe-discovery shortlist only: include a token only if at least one executed run used scope universe. Do not promote holdings-only screens into candidates.",
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "token_id",
          "symbol",
          "candidate_reason",
          "source_run_ids"
        ],
        "properties": {
          "token_id": {
            "type": "string",
            "minLength": 1
          },
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "candidate_reason": {
            "type": "string",
            "minLength": 1,
            "description": "Substantive justification: name specific DD indicators, scores, or filter outcomes from screen results for this token—not only template/query id (that belongs in source_run_ids). Cite values, bands, or rank basis where possible."
          },
          "source_run_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "coingecko_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "chain": {
            "type": "string"
          },
          "contract_address": {
            "type": "string"
          },
          "indicator_snapshot": {
            "type": "object",
            "description": "Optional excerpt of indicator fields from the screen result row to support candidate_reason without pasting long prose."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
