# Copy to .env and fill in real values. Used by install.sh and update.sh for MCP runtime config.
# Do not commit .env (it is gitignored).

MESSY_VIRGO_MCP_URL=https://api.messyvirgo.com/mcp
MESSY_VIRGO_API_KEY=your-api-key

# Optional: override config/workspaces paths (used by install/update/remove)
# OPENCLAW_CONFIG_DIR=$HOME/.openclaw-secure
# OPENCLAW_WORKSPACES_DIR=$HOME/OpenClawWorkspaces
